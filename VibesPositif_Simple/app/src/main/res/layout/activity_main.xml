<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#F0F4FF">

    <!-- Logo bintang -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✨"
        android:textSize="80sp"
        android:layout_marginBottom="8dp"/>

    <!-- Nama aplikasi -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vibes Positif+"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1A6AC0"
        android:layout_marginBottom="4dp"/>

    <!-- Tagline -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Afirmasi harian untuk pikiran & hati"
        android:textSize="13sp"
        android:textColor="#666666"
        android:layout_marginBottom="48dp"/>

    <!-- Card putih -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="24dp"
        android:gravity="center">

        <!-- Greeting -->
        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selamat datang!"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A6AC0"
            android:layout_marginBottom="20dp"/>

        <!-- Divider -->
        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:background="#D6E3FF"
            android:layout_marginBottom="20dp"/>

        <!-- Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Afirmasi hari ini:"
            android:textSize="12sp"
            android:textColor="#888888"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"/>

        <!-- Affirmation text -->
        <TextView
            android:id="@+id/tvAffirmation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading..."
            android:textSize="18sp"
            android:textColor="#1A1C1E"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"/>

    </LinearLayout>

    <!-- Footer -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Afirmasi berganti setiap hari 🌟"
        android:textSize="11sp"
        android:textColor="#AAAAAA"
        android:layout_marginTop="32dp"/>

</LinearLayout>
